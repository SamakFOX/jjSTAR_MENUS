/**
 * @class 숫자/대문자/소문자/특수문자를 지정한 길이만큼 랜덤생성하여 Return 한다.
 * @param iLength
 * @param bNumber
 * @param bUpper
 * @param bLower
 * @param bSpecialChar
 * @return String 랜덤생성된 문자열.
 */
comUtil.gfn_getRandomText = function (iLength, bNumber, bUpper, bLower, bSpecial)
{
	var arr = [];

	var characters = "";
	characters += this.gfn_isNull(bUpper  ) || bUpper   ? "ABCDEFGHIJKLMNOPQRSTUVWXYZ" : "";
	characters += this.gfn_isNull(bLower  ) || bLower   ? "abcdefghijklmnopqrstuvwxyz" : "";
	characters += this.gfn_isNull(bNumber ) || bNumber  ? "0123456789" : "";
	characters += this.gfn_isNull(bSpecial) || bSpecial ? "!\"#$%&'()*+,-./:;< => ?@[￦]^_`{|}~" : "";
	var charactersLength = characters.length;



	for (var ii = 0; ii < iLength; ii++) 
	{
		arr.push(characters.charAt(Math.floor(Math.random() * charactersLength)));
	}

	return arr.join("");
};
