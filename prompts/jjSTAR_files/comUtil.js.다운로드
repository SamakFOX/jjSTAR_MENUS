/**
 * @class 입력된 문자열의 일부분을 다른 문자열로 치환하는 함수
 * @param strString 원본 문자열.
 * @param strOld    원본 문자열에서 찾을 문자열.
 * @param strNew    새로 바꿀 문자열.
 * @return String 대체된 문자열
 */
comUtil.gfn_replace = function (val, strOld, strNew)
{
	val = this.gfn_toString(val);
	val = val.split(eval("/" + strOld + "/g")).join(strNew);
	// val = val.split(strOld).join(strNew);

	if (val.indexOf(strOld) > -1)
	{
		return this.gfn_replace(val, strOld, strNew);
	}
	else
	{
		return val;
	}
}

/**
 * @class 입력된 문자열의 좌우측 공백을 제거한 문자열을 구함.
 * @param arg(좌우측 공백문자를 제거하려는 문자열)
 * @return {String} 입력된 문자열에서 좌우측 공백이 제거된 문자열
 * @example
 */
comUtil.gfn_trim = function (sValue)
{
	if (this.gfn_isNull(sValue))
	{
		return "";
	}

	var retVal = (new String(sValue)).replace(/^\s+|\s+$/g, '');

	return retVal;
}

/**
 * @class  입력된
 * @param  소수점 있는 값, 반올림할 위치( > 0 == 소수 반올림,  < 0 == 정수 반올림)
 * @return {String} 입력된 문자열에서 좌우측 공백이 제거된 문자열
 * @example
 */
comUtil.gfn_round = function(nValue, nPosition)
{
	var nResult = nValue;

	// 반올림할 대상의 위치가 소수점이라면... (4.455, 2)
	if (nPosition > 0)
	{
		var iMultiply = parseInt(this.gfn_rpad("1", nPosition + 1, "0"));

		nResult = Math.round((nValue * iMultiply).toFixed(nPosition)) / iMultiply;
	}
	else if (nPosition < 0)
	{
		nResult = nexacro.round(nValue, nPosition);
	}

	return nResult;
}

