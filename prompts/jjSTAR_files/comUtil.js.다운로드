/**
 * @class 숫자에 ","를 집어넣기
 * @param sNum: 문자열
 * @return 포맷된 문자
 */
comUtil.gfn_setComma = function (sNum)
{
	"use strict";

	// 숫자변환이 불가능하면 널값으로 리턴.
	if (sNum != nexacro.toNumber(sNum))
	{
		return null;
	}

	var nNum = nexacro.toNumber(sNum);
	var isMinusValue = nNum < 0;
	
	
	sNum = this.gfn_toString(Math.abs(nNum));
	var iDotPos = sNum.indexOf(".");
	var sNum1 = sNum.substr(0, iDotPos == -1 ? sNum.length : iDotPos);
	var sNum2 = iDotPos == -1 ? "" : sNum.substr(iDotPos, sNum.length);

	var iComma = (sNum1.length - 1) % 3;

	var sss = "";

	for (var ii = 0; ii < sNum1.length; ii++)
	{
		sss += sNum1.substr(ii, 1);
		sss += (ii % 3 == iComma) && (ii < sNum1.length - 1) ? "," : "";
	}

	return (isMinusValue ? "-" : "") + sss + sNum2;
}
