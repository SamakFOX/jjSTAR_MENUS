/**
 * @class Grid에서 expression으로  표현할때 decode 문처럼 사용할 수 있는 기능.
 * @param decode(strVal, "test", true, false);
 * @return varRtnValue 로 decode 조건에 맞는 값 리턴.
 */
comUtil.gfn_decode = function ()
{
	var ii;

	var rtnValue = null;

	// arguments는 무조건 짝수로 들어와야 함.
	if (arguments.length % 2 != 0)
	{
		alert("함수에 사용된 arguments 값이 짝수가 아닙니다.");
	}

	// arguments는 무조건 짝수로 들어와야 함.
	if (arguments.length < 4)
	{
		alert("함수의 arguments는 최소 4개를 입력하세요.");
	}

	for (ii = 1; ii < arguments.length; ii++)
	{
		if (ii % 2 == 1) // 홀수번째는 조건입니다.
		{
			if (arguments[ii] == arguments[0]) // 0번째 조건과 값은 값이라면 중지합니다.
			{
				return arguments[ii + 1];
			}
			else if (ii == arguments.length - 1) // 마지막 값이라면 중지합니다.
			{
				return arguments[ii];
			}
		}
	}
}

/**
 * @class 입력값이 null에 해당하는 경우 모두를 한번에 체크한다.
 * @param Val : 체크할 문자열(예 : null 또는 undefined 또는 "" 또는 "abc")
 * @return Boolean,	Val이 undefined, null, NaN, "", Array.length = 0인 경우 = true
 *					이외의 경우 = false
 */
comUtil.gfn_nvl = function (val, val2)
{
	var rtnVal = (this.gfn_isNull(val)) ? val2 : val;
	
	return rtnVal;
}

/**
 * @class 입력값이 null에 해당하는 경우 모두를 한번에 체크한다.
 * @param Val : 체크할 문자열(예 : null 또는 undefined 또는 "" 또는 "abc")
 * @return Boolean,	Val이 undefined, null, NaN, "", Array.length = 0인 경우 = true
 *					이외의 경우 = false
 */
comUtil.gfn_isNotNull = function (val)
{
	return this.gfn_isNull(val) == false;
}

comUtil.gfn_isNull = function (val)
{
	// 전달받은 변수를 문자열로 변경합니다.
	var sValue = new String(val);

	// 변수값 비교
	if (
		   val === undefined
		|| val ==  undefined
		|| val ==  null     
			   
		// 문자열로 변경하여 널값 비교
		|| sValue           == null
		|| sValue.valueOf() == "undefined"
		|| sValue.valueOf() == "null"     
		|| sValue           == "NaN"
		|| sValue.trim()    == ""  
		|| sValue.length    == 0   ) return true;

	return false;
}

/**
 * @class 왼쪽 채우기 함수
 * @param sValue 	- 대상문자열
 * @param nLength 	- 자리수
 * @param Char 		- 채울 문자
 * @return String
 * @memberOf commString
 */
comUtil.gfn_lpad = function (sValue, nLength, sChar)
{
	if (new String(sValue).valueOf() == "undefined")
	{
		sValue = "";
	}
	
	if (this.gfn_isNull(sValue))
	{
		sValue = "";
	}
		

	var strRetVal = new String(sValue);
	var strChar = "";
	var nIteration = (nLength - this.gfn_getByteLength(strRetVal)) / sChar.length + 1;

	for (var i = 0; i < nIteration; i++)
	{
		strChar = sChar + strChar;
	}

	return (this.gfn_right(strChar + strRetVal, nLength));
}

/**
 * @class 오른쪽 채우기 함수
 * @param sValue 	- 대상문자열
 * @param nLength 	- 자리수
 * @param Char 		- 채울 문자
 * @return String
 * @memberOf commString
 */
comUtil.gfn_rpad = function (sValue, nLength, Char)
{
	if (new String(sValue).valueOf() == "undefined")
	{
		sValue = "";
	}
	
	if (this.gfn_isNull(sValue))
	{
		sValue = "";
	}

	var strRetVal = new String(sValue);
	var nIteration = (nLength - this.gfn_getByteLength(strRetVal)) / Char.length + 1;

	for (var i = 0; i < nIteration; i++)
	{
		strRetVal = strRetVal + Char;
	}

	return this.gfn_left(strRetVal, nLength);
}

