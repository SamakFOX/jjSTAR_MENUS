    	// url 잘라내기
    	var gv_url_min  = nexacro.getProjectPath();								// http://localhost:8080/juis/
    	var gv_url_host = gv_url_min.substr(0, gv_url_min.indexOf("=", 9) + 1);	// http://localhost:8080/

    	// 개발서버 여부
    	var gv_isLocal =    (gv_url_host.indexOf("file"     ) != -1)
    	                 || (gv_url_host.indexOf("localhost") != -1)
    	                 || (gv_url_host.indexOf("127.0.0.1") != -1);

    	// file://  일 경우에는 미리 지정된 서버주소를 사용합니다.
    	if (gv_url_min.indexOf('file://') != -1)
    	{
    		//gv_serverUrl = nexacro.getEnvironment().services["svcurl"].url;
    	}
    	else
    	{
    		//this.gv_serverUrl           = this.gv_url_host
    		nexacro.getEnvironment().services["svcurl"].url = gv_url_host;
    		nexacro.getEnvironment().services["svcjsp"].url = gv_url_min + "JSP/";
    	}


    	var ss = document.location.href.toLowerCase();

    	if (ss.indexOf("=jjip") != -1)
    	{
    		this.GV_WORKTYPE = "JJIP";
    		nexacro.setPrivateProfile("JJSTAR_GRP", "I");
    	}
    	else if (ss.indexOf("=jjie") != -1)
    	{
    		this.GV_WORKTYPE = "JJIE";
    		nexacro.setPrivateProfile("JJSTAR_GRP", "I");
    	}
    	else if (ss.indexOf("=jjpp") != -1)
    	{
    		this.GV_WORKTYPE = "JJPP";
    		nexacro.setPrivateProfile("JJSTAR_GRP", "P");
    	}
    	else if (ss.indexOf("=jjap") != -1)
    	{
    		this.GV_WORKTYPE = "JJAP";
    		nexacro.setPrivateProfile("JJSTAR_GRP", "A");
    	}
    	else if (ss.indexOf("=jjpa") != -1)
    	{
    		this.GV_WORKTYPE = "JJPA";
    		nexacro.setPrivateProfile("JJSTAR_GRP", "R");			//학부모
    	}
    	else
    	{
    		this.GV_WORKTYPE = null;
    		nexacro.setPrivateProfile("JJSTAR_GRP", "U");
    	}
