comDate.lfn_getOnlyNumber = function(ADate)
{
	var fv_arr = [];

	// 변수가 비었습니다.
	if (comUtil.gfn_isNull(ADate)) return null;

	// 변수가 문자열이라면 정상입니다.
	if (ADate instanceof Date) ADate = this.gfn_dateToStr(ADate);

	ADate = new String(ADate);
	
	// 숫자만 추출
	for (var ii = 0; ii < ADate.length; ii++)
	{
		var ss = ADate[ii];

		if (["1", "2", "3", "4", "5", "6", "7", "8", "9", "0"].indexOf(ss) >= 0) 
		{
			fv_arr.push(ss);
		}
	}

	return fv_arr.join("");
};

