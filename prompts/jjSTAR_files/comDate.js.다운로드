/*================================================================================
 - this.gfn_todayClient ; PC에서 날짜 및 시간을 json 타입으로 리턴합니다.
================================================================================*/
comDate.gfn_todayPC = function()
{
	var d = new Date();
	
	var json = {};
	
	json.YYYY = "" + d.getFullYear();
	json.MM   = ("0" + (d.getMonth() + 1)  ).substr(-2);
	json.DD   = ("0" + d.getDate()   ).substr(-2);
									 
	json.HH   = ("0" + d.getHours()  ).substr(-2);
	json.MI   = ("0" + d.getMinutes()).substr(-2);
	json.SS   = ("0" + d.getSeconds()).substr(-2);
	json.ZZZ  = ("000" + d.getMilliseconds()).substr(-3);
								 
	json.YYYYMMDD  = json.YYYY + json.MM + json.DD;
	json.HHMISS    = json.HH   + json.MI + json.SS;
	json.HHMISSZZZ = json.HH   + json.MI + json.SS + json.ZZZ;
	
	return json;
};

/*================================================================================
 - this.gfn_strToDate ; 8자리 날짜를 Date 형식으로 리턴합니다.
 - this.gfn_strToDateTime ; 14자리 날짜를 Date 형식으로 리턴합니다. // 18.04.12. 추가 김현철
 - this.gfn_dateStrToRPAD ; String 일자 형식을 받아서 RPAD로 0을 채워서 리턴하는 함수입니다. // 18.04.12. 추가 김현철
 ---> 예시: this.gfn_dateStrToRPAD('20180412173123') ---> RTN: '20180412173123000' // 용도: dataset datetime setColumn
 - this.gfn_dateToStr ; Date 형식을 8자리 날짜로 리턴합니다.
 ================================================================================*/
comDate.gfn_strToDate = function (ADate)
{
	if (comUtil.gfn_isNull(ADate)) return null;
	
	// 받은 변수가 문자열이면 그대로 리턴합니다.
	if (ADate instanceof Date) return ADate;

	// 문자열로 변환
	ADate = String(ADate);
	
	// 문자열 날짜형식은 8자리입니다.
	if (ADate.length != 8) return null;
	
	var nYYYY = parseInt(ADate.substr(0, 4));
	var nMM   = parseInt(ADate.substr(4, 2)) - 1;
	var nDD   = parseInt(ADate.substr(6, 2));
	
	return new Date(nYYYY, nMM, nDD);
};

comDate.gfn_strToDateTime = function (ADate)
{
	if (comUtil.gfn_isNull(ADate)) return null;
	
	// 받은 변수가 문자열이면 그대로 리턴합니다.
	if (ADate instanceof Date) return ADate;

	// 문자열로 변환
	ADate = String(ADate);
	
	// 문자열 날짜형식은 14자리입니다.
	if (ADate.length < 14) return null;
	
	var nYYYY = parseInt(ADate.substr(0, 4));
	var nMM   = parseInt(ADate.substr(4, 2)) - 1;
	var nDD   = parseInt(ADate.substr(6, 2));
	var nHH   = parseInt(ADate.substr(8, 2));
	var nMI   = parseInt(ADate.substr(10, 2));
	var nSS   = parseInt(ADate.substr(12, 2));
	
	return new Date(nYYYY, nMM, nDD, nHH, nMI, nSS);
};

comDate.gfn_dateStrToRPAD = function (ADate)
{
	if (comUtil.gfn_isNull(ADate)) return null;
	
	// 
	if (ADate.length < 8) return ADate;

	// 문자열로 변환
	ADate = String(ADate);
	
	// 17자리까지 0으로 채운다.
	ADate = comUtil.gfn_rpad(ADate, 17, "0");
	return ADate;
};

comDate.gfn_dateToStr = function(ADate)
{
	if (comUtil.gfn_isNull(ADate)) return null;

	if (typeof ADate == "string") ADate = new Date(ADate.substr(0, 4), ADate.substr(4, 2) - 1, ADate.substr(6, 2));

	var sYYYY = ADate.getFullYear();
	var sMM   = ADate.getMonth() + 1;
	var sDD   = ADate.getDate();

	sMM = comUtil.gfn_lpad(sMM, 2, "0");
	sDD = comUtil.gfn_lpad(sDD, 2, "0");

	return sYYYY + sMM + sDD;
};



comDate.gfn_dateToKor = function(ADate, wType)
{
	/*
		wType
		N-none, S-short, F-full
	*/
	if (comUtil.gfn_isNull(ADate)) return null;
	var str_weekNm = comDate.gfn_getDateDayName(ADate);
	if (typeof(ADate) == "string") ADate = new Date(ADate.substr(0, 4), ADate.substr(4, 2)-1, ADate.substr(6, 2));



	var sYYYY = ADate.getFullYear();
	var sMM   = ADate.getMonth() + 1;
	var sDD   = ADate.getDate();

	sMM = comUtil.gfn_lpad(sMM, 2, "0");
	sDD = comUtil.gfn_lpad(sDD, 2, "0");

	var str_w = "";
	
	switch(wType) {
		case "N" : 
			str_w = "";
			break;
			
		case "S" : 
			str_w = " ("+str_weekNm.substr(0,1)+")";
			break;
			
		case "F" : 
			str_w = " "+str_weekNm;
			break;
	}
	
	return sYYYY+"년 " + sMM+"월 " + sDD+"일"+str_w;
}

/*================================================================================
 - this.gfn_getDateFirst      : 입력받은 날짜의 첫날을 리턴합니다.        20170101
 - this.gfn_getDateLast       : 입력받은 날짜의 마지막 날짜를 리턴합니다. 20170131
================================================================================*/
comDate.gfn_getDateFirst = function (ADate)
{
	// 입력받은 날짜가 없다면 중지합니다.
	if (comUtil.gfn_isNull(ADate)) return "";
	
	// 입력받은 날짜가 Date 형식이라면 문자열로 변경합니다.
	ADate = this.gfn_dateToStr(ADate);
	
	return ADate.substr(0, 6) + "01";
};

comDate.gfn_getDateLast = function (ADate)
{
	// 입력받은 날짜가 없다면 중지합니다.
	if (comUtil.gfn_isNull(ADate)) return "";

	// 입력받은 날짜가 Date 형식이라면 문자열로 변경합니다.
	if (ADate instanceof Date) ADate = this.gfn_dateToStr(ADate);

	// 날짜를 1일로 수정합니다.
	ADate = ADate.substr(0, 6) + "01";

	// 날짜를 1달 더합니다.
	ADate = this.gfn_getDateAddMonth(ADate, 1);

	// 날짜를 1일 뺍니다.
	ADate = this.gfn_getDateAddDay(ADate, -1);

	return this.gfn_dateToStr(ADate);
};

/*================================================================================
 - this.gfn_getDateAddMonth   : 입력받은 날짜에 월을 더하거나 뺍니다.
 - this.gfn_getDateAddDay     : 입력받은 날짜에 일을 더하거나 뺍니다.
================================================================================*/
comDate.gfn_getDateAddMonth = function (ADate, nOffSet)
{
	// 입력된 날짜가 비어있다면 중지합니다.
	if (comUtil.gfn_isNull(ADate)) return "";
	
	// 입력받은 날짜를 문자열로 변경합니다.
	var fv_newDate = this.gfn_dateToStr(ADate);
	
	// 입력받은 날짜를 년/월/일로 분리하고, 월은 offset 만큼 더해줍니다.
	var nYYYY = parseInt(fv_newDate.substr(0, 4)),
		nMM = parseInt(fv_newDate.substr(4, 2)) + nOffSet,
		nDD = parseInt(fv_newDate.substr(6, 2));

	// 분리한 년/월/일을 합칩니다.
	fv_newDate = new Date(nYYYY, nMM - 1, nDD);
	fv_newDate = this.gfn_dateToStr(fv_newDate);

	// 입력날짜와 더해진 날짜의 일자가 같다면 +-1을 합니다.
//	if (ADate.substr(-2) == fv_newDate.substr(-2))
//	{
//		fv_newDate = this.gfn_getDateAddDay(fv_newDate, nOffSet > 0 ? -1 : 1);
//	}

	return this.gfn_dateToStr(fv_newDate);
};

comDate.gfn_getDateAddDay = function (ADate, nOffSet)
{
	if (comUtil.gfn_isNull(ADate)) return "";

	ADate = this.gfn_dateToStr(ADate);

	var nYYYY = parseInt(ADate.substr(0, 4));
	var nMM   = parseInt(ADate.substr(4, 2));
	var nDD   = parseInt(ADate.substr(6, 2)) + nOffSet;

	return this.gfn_dateToStr(new Date(nYYYY, nMM - 1, nDD));
};

/*================================================================================
 - this.gfn_getDateAddMonth   : 입력받은 날짜에 월을 더하거나 뺍니다.
 - this.gfn_getDateAddDay     : 입력받은 날짜에 일을 더하거나 뺍니다.
================================================================================*/
comDate.gfn_getDateDiffDay = function (ADateFrom, ADateTo)
{
	var ADateFrom = this.gfn_strToDate(ADateFrom);
	var ADateTo   = this.gfn_strToDate(ADateTo);

	var ADateDiff = ADateTo - ADateFrom;

	return Math.trunc(ADateDiff / 86400 / 1000) + 1;
};

comDate.gfn_getDateDiffMonth = function (ADateFrom, ADateTo)
{
	var ADatePrev;
	var ADateFrom = this.gfn_dateToStr(ADateFrom);
	var ADateTo   = this.gfn_dateToStr(ADateTo);

	var ii = 0;

	// 1개월씩 올려서 1 증가시킵니다.
	while (true)
	{
		ADatePrev = ADateFrom;
		
		// 1개월 증가
		ADateFrom = this.gfn_getDateAddMonth(ADateFrom, 1);
		
		// 증가시킨 날이 종료일보다 작다면...
		if (ADateFrom > ADateTo) 
		{
			// 증가시킨 날에서 1일을 뺐을때, 종료일과 동일하다면 1개월로 칩니다.
			if (this.gfn_getDateAddDay(ADateFrom, -1) == ADateTo) ii++;
		
			break;
		}
		
		ii++;
	}

	return ii;
};

/**
