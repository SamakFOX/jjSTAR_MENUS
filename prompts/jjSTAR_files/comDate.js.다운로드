comDate.gfn_getDateTimeFormat = function(ADate, AFormat)
{
	var fv_str = ADate;
	var obj = this.calendar4Format;
	
	if (obj == null)
	{
		obj = new nexacro.Calendar("calendar4Format", "absolute", 0, 0, 0, 0, null, null);
		//this.addChild("calendar4Format", obj);
		//obj.show();
	}
	
	if (ADate instanceof Date)
	{
		fv_str = "";
		
		fv_str += ("0000" + ADate.getYear()).substr(-4);
		fv_str += ("0" + (ADate.getMonth() + 1)).substr(-2);
		fv_str += ("0" + ADate.getDate()).substr(-2);
		
		fv_str += ("0" + ADate.getHours()).substr(-2);
		fv_str += ("0" + ADate.getMinutes()).substr(-2);
		fv_str += ("0" + ADate.getSeconds()).substr(-2);
		fv_str += ("0" + ADate.getMilliseconds()).substr(-2);
	}

	obj.set_dateformat(AFormat);
	obj.set_editformat(AFormat);
	obj.set_value(fv_str);
	
	return obj.text;
};

this.gfn_numToHHMMSS = function (num, sSeperate)
{
	sSeperate = this.gfn_nvl(sSeperate, ":");
	
    var num     = nexacro.toNumber(num);
    var iHour   = Math.floor(num / 3600);
    var iMinute = Math.floor((num - (iHour * 3600)) / 60);
    var iSecond = num - (iHour * 3600) - (iMinute * 60);

    iHour   = ("0" + iHour  ).substr(-2);
    iMinute = ("0" + iMinute).substr(-2);
    iSecond = ("0" + iSecond).substr(-2);
    
    return iHour + sSeperate + iMinute + sSeperate + iSecond;
};
