/**
 * @class 입력된 날자로부터 요일명을 구함
 * @param sFdate   sDate  8자리 형식으로된 날짜. yyyyMMdd의 형식으로 입력됩니다.
 * @return 요일명
 */
comDate.gfn_getDateMonthEngName = function (ADate, isShort, caseULN)
{
	caseULN = (caseULN || "N").toUpperCase();
	
	if (comUtil.gfn_isNull(ADate)) return "";

	var ADate = this.gfn_strToDate(ADate);

	var arr = ["January", "February", "March", "April", "May", "June", "July", "August", "September", "October", "November", "December"];

	var ss = arr[ADate.getMonth()];
	
	if (isShort)
	{
		ss = ss.substr(0, 3);
}

	ss = comUtil.gfn_decode(caseULN
		, "U", ss.toUpperCase()
		, "L", ss.toLowerCase()
		, ss);

	return ss;
};

/**
 * @class 윤년여부 확인
 * @param sDate : yyyyMMdd형태의 날짜 ( 예 : "20121122" )
 * @return sDate가 윤년인 경우 = true
 *		   sDate가 윤년이 아닌 경우 = false
 *		   sDate가 입력되지 않은 경우 = false
 */  
comDate.gfn_getDateIsLeapYear = function (ADate)
{
	var nYear;

	if (comUtil.gfn_isNull(ADate)) return false;

	ADate = this.gfn_dateToStr(ADate);

	nYear = parseInt(ADate.substring(0, 4), 10);

	// 400으로 나눈 나머지가 0이거나
	// 4로 나눈 나머지는 0이고, 100으로 나눈 나머지는 0이 아닐때
	// 윤년입니다.

	return (nYear % 4 == 0 && nYear % 100 != 0) || nYear % 400 == 0;
};

