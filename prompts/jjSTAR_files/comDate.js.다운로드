	//  	ADate = ADate.replace(".","").replace(".","");
		
		// 숫자길이가 8자리가 아니라면 실패
		if (ADate.toString().length !== 8) return false;
		
		// 문자 -> 날짜 -> 문자로 변환
		var ADate2 = this.gfn_dateToStr(this.gfn_strToDate(ADate));

		// 받은 변수와, 변환한 결과값이 같다면 정상.
		// 20161232 != 20170101
		return ADate == ADate2;
	}
};

comDate.gfn_getDateList = function(AFrom, ATo)
{
	AFrom = this.gfn_dateToStr(AFrom);
	ATo   = this.gfn_dateToStr(ATo  );
	
	var arr = [];
	var nCnt = this.gfn_getDateDiffDay(AFrom, ATo);
	
	for (var ii = 0; ii < nCnt; ii++)
	{
		arr.push(this.gfn_getDateAddDay(AFrom, ii));
	}
	
	return arr;
};

comDate.gfn_getDateAddSeperator = function(ADate, strSep, strEnd)
{
	if (comUtil.gfn_isNull(ADate)) return null;

	if (typeof ADate == "string") ADate = new Date(ADate.substr(0, 4), ADate.substr(4, 2) - 1, ADate.substr(6, 2));

	var sYYYY = ADate.getFullYear();
	var sMM   = ADate.getMonth() + 1;
	var sDD   = ADate.getDate();

	sMM = comUtil.gfn_lpad(sMM, 2, "0");
	sDD = comUtil.gfn_lpad(sDD, 2, "0");

	return sYYYY + strSep + sMM + strSep + sDD + strEnd;
};

