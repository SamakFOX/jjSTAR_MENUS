/**
 * @class 시분 체크
 * @param value 시분 value
 * @return Boolean
 */
comValid.gfn_isTimeHHmm = function(value)
{
	if (this.gfn_isNull(value))
	{
		return false;
	}
	
    if (value.trim().toString().length != 4)
	{
        return false;
    }
    
    var nHH = nexacro.toNumber(value.toString().substr(0,2));
    var nMM = nexacro.toNumber(value.toString().substr(2,2));
       
    if (this.gfn_isNull(nHH) || this.gfn_isNull(nMM))
	{
		return false;
    }
    
    if (nHH > 23 || nHH < 0)
	{
		return false;
    }
    
    if (nMM > 59 || nMM < 0)
	{
		return false;
    }
    
    return true;
}

/**
 * @class 시분초 체크
 * @param value 시분초 value
 * @return Boolean
 */
comValid.gfn_isTimeHHmmss = function(value)
{
	if (comUtil.isNull(value))
	{
		return false;
	}
	
    if (value.trim().toString().length != 6)
	{
        return false;
    }
    
    var nHH = nexacro.toNumber(value.toString().substr(0,2));
    var nMM = nexacro.toNumber(value.toString().substr(2,2));
    var nSS = nexacro.toNumber(value.toString().substr(4,2));
    
    if (comUtil.gfn_isNull(nHH) || comUtil.gfn_isNull(nMM) || comUtil.gfn_isNull(nSS))
	{
		return false;
    }
    
    if (nHH > 23 || nHH < 0)
	{
		return false;
    }
    
    if (nMM > 59 || nMM < 0)
	{
		return false;
    }
    
    if (nSS > 59 || nSS < 0)
	{
		return false;
    }
    
    return true;
}